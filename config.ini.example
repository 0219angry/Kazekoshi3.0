[DEFAULT]
# ─── Discord ─────────────────────────────────────────────────────
DISCORD_TOKEN      = your_discord_bot_token_here
COMMAND_PREFIX     = !

# ─── 読み上げ（edge-tts） ─────────────────────────────────────────
# デフォルトの読み上げボイス（!voice コマンドで個人設定可能）
# 選択肢: ja-JP-NanamiNeural / ja-JP-AoiNeural / ja-JP-MayuNeural /
#         ja-JP-ShioriNeural / ja-JP-KeitaNeural / ja-JP-DaichiNeural / ja-JP-NaokiNeural
DEFAULT_VOICE      = ja-JP-NanamiNeural

# ─── OpenWeatherMap ──────────────────────────────────────────────
OPEN_WEATHER_MAP_TOKEN = your_openweathermap_api_key_here

# デフォルト拠点の座標（変更でどこでもOK）
DEFAULT_LAT  = 35.6895
DEFAULT_LON  = 139.6917
DEFAULT_CITY = 東京

# ─── Google Gemini AI ────────────────────────────────────────────
# /ai コマンドやメンション応答で使用（無料枠: 1500 req/day, 15 RPM）
# https://aistudio.google.com/apikey でAPIキーを取得
# 不要なら空のままにしてください（AI機能が無効になります）
GEMINI_API_KEY     = your_gemini_api_key_here
