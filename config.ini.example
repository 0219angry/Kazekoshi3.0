[DEFAULT]
# ─── Discord ─────────────────────────────────────────────────────
DISCORD_TOKEN      = your_discord_bot_token_here
COMMAND_PREFIX     = !

# ─── VOICEVOX ────────────────────────────────────────────────────
# デフォルトの話者ID（3 = ずんだもんノーマル）
SPEAKER_ID         = 3
OPEN_JTALK_DICT_DIR = open_jtalk_dic_utf_8-1.11

# ─── OpenWeatherMap ──────────────────────────────────────────────
OPEN_WEATHER_MAP_TOKEN = your_openweathermap_api_key_here

# デフォルト拠点の座標（変更でどこでもOK）
DEFAULT_LAT  = 35.6895
DEFAULT_LON  = 139.6917
DEFAULT_CITY = 東京

# ─── Google Gemini AI ────────────────────────────────────────────
# /ai コマンドやメンション応答で使用（無料枠: 1500 req/day, 15 RPM）
# https://aistudio.google.com/apikey でAPIキーを取得
# 不要なら空のままにしてください（AI機能が無効になります）
GEMINI_API_KEY     = your_gemini_api_key_here

# ─── YouTube (yt-dlp) ────────────────────────────────────────────
# Bot検出回避用クッキーファイルのパス（Netscape形式 cookies.txt）
# 空のままにすると未使用（YouTube がBot判定した場合に設定）
# エクスポート方法: https://github.com/yt-dlp/yt-dlp/wiki/FAQ#how-do-i-pass-cookies-to-yt-dlp
YOUTUBE_COOKIES_FILE = cookies.txt
